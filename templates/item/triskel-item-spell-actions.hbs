<section
  class="tab item-panel {{tabs.spells.id}} {{tabs.spells.cssClass}}"
  data-tab="{{tabs.spells.id}}"
  data-group="{{tabs.spells.group}}"
>
  <h2>Spells</h2>
  <ol class="reference-entries">
    {{#each references.spellActions as |reference|}}
      <li class="reference-row">
        <span class="reference-label">{{reference.label}}</span>
        <button type="button" data-action="removeSpellActionReference" data-index="{{reference.index}}">Entfernen</button>
      </li>
    {{/each}}
    {{#unless references.spellActions.length}}
      <li class="reference-row reference-row--empty">Keine Referenzen hinterlegt</li>
    {{/unless}}
  </ol>

  <div class="reference-controls__inputs">
    <select
      id="spell-actions-reference-select"
      name="spellActionsRef"
      data-reference-select="spellActions"
    >
      {{#each referenceOptions.spellActions as |option|}}
        <option value="{{option.value}}">{{option.label}}</option>
      {{/each}}
    </select>

    <button
      type="button"
      data-action="addSpellActionReference"
      data-select-field="spellActionsRef"
      data-ref-path="system.spellActions.ref"
    >
      Hinzufügen
    </button>
  </div>
</section>
